# macOS
.DS_Store

# Obsidian — per-machine state (not portable across collaborators)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/workspace.json.bak
.obsidian/cache/

# Obsidian trash
.trash/

# Node
node_modules/

# Conda — if env is created in-tree
.conda/
envs/

# Raw source material — not redistributable (copyright)
raw/papers/*
!raw/papers/.gitkeep
raw/articles/*
!raw/articles/.gitkeep
raw/transcripts/*
!raw/transcripts/.gitkeep
raw/assets/*
!raw/assets/.gitkeep
# Per-paper exception: Vaswani et al. 2017 figures.
# The arXiv v7 tarball grants: "Provided proper attribution is provided,
# Google hereby grants permission to reproduce the tables and figures in
# this paper solely for use in journalistic or scholarly works."
!raw/assets/1706.03762-*
